# Claw Installer production env
NODE_ENV=production
PORT=3005
NEXTAUTH_URL=https://clawinstaller.xyz
NEXTAUTH_SECRET=

# Database
MONGODB_URI=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin
# Comma-separated list of admin emails. These emails can access /dashboard/admin
ADMIN_EMAILS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TIER1=
STRIPE_PRICE_TIER2=
STRIPE_PRICE_TIER3=

# NowPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# GCP provisioner
GCP_PROJECT_ID=
GCP_ZONE=us-central1-c
# JSON string or base64-encoded service account key (preferred)
GCP_SERVICE_ACCOUNT_KEY=
GCP_BASE_IMAGE=
